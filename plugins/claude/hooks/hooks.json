{
  "description": "Push Claude Code lifecycle events to llmux tmux session state",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "idle"] }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "working"] }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "waiting"] }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "working"] }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "working"] }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "working"] }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "waiting"] }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "waiting"] }
        ]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "working"] }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog|agent_needs_input",
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "waiting"] }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "idle"] }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "idle"] }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "waiting"] }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "llmux", "args": ["state", "idle"] }
        ]
      }
    ]
  }
}
